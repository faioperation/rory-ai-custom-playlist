# =============================================================================
# Frontend Environment Variables
# Soundtrack My Night — React 19 + Vite 7
# =============================================================================
# Copy this file: cp frontend/.env.example frontend/.env
# IMPORTANT: Vite variables are embedded at BUILD TIME, not runtime.
# Changing this file after a build has no effect without rebuilding.
# =============================================================================

# ── Backend API Base URL ──────────────────────────────────────────────────────
# The base URL of the backend API, used by axiosInstance (axiosInstance.js).
#
# Development (no Docker):
#   VITE_BACKEND_URL=http://localhost:3000
#
# Development (Docker Compose):
#   VITE_BACKEND_URL=http://localhost:3000
#   (Browser talks to the host-exposed port 3000)
#
# Production (Docker Compose with nginx reverse proxy):
#   VITE_BACKEND_URL=
#   (Leave EMPTY — axios uses relative URLs e.g. /api/v1/...
#    which nginx routes to backend:3000 internally)
#
# Production (different domain for API):
#   VITE_BACKEND_URL=https://api.soundtrackmynight.com
#
VITE_BACKEND_URL=http://localhost:3000
