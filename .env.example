# =============================================================================
# Soundtrack My Night — Root Environment Reference
# =============================================================================
# This file documents ALL environment variables across all three services.
# It is for reference only. Each service has its own .env.example:
#
#   backend/.env.example  — Node.js backend vars
#   ai/.env.example       — FastAPI AI service vars
#   frontend/.env.example — Vite frontend vars (build-time only)
#
# Quick start:
#   cp backend/.env.example  backend/.env
#   cp ai/.env.example       ai/.env
#   cp frontend/.env.example frontend/.env
# =============================================================================

# =============================================================================
# BACKEND (backend/.env)
# =============================================================================
PORT=3000
NODE_ENV=production
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smn_db
JWT_SECRET=replace_with_a_64_char_random_string
JWT_EXPIRES_IN=30d
FRONTEND_URL=https://soundtrackmynight.com
BACKEND_URL=https://soundtrackmynight.com
ALLOWED_ORIGIN=https://soundtrackmynight.com
AI_ENDPOINT=http://ai:8000
EMAIL_USER=info@soundtrackmynight.com
EMAIL_PASS=replace_with_your_email_password
STRIPE_SECRET_KEY=sk_live_replace_with_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

# =============================================================================
# AI SERVICE (ai/.env)
# =============================================================================
OPENAI_API_KEY=sk-replace_with_your_openai_api_key
SPOTIFY_CLIENT_ID=replace_with_your_spotify_client_id
SPOTIFY_CLIENT_SECRET=replace_with_your_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=replace_with_your_spotify_refresh_token

# =============================================================================
# FRONTEND (frontend/.env) — BUILD-TIME ONLY
# =============================================================================
# Leave empty in production (nginx reverse proxy handles routing)
VITE_BACKEND_URL=
