__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
*.egg

# Test artefacts
.pytest_cache/
.coverage
htmlcov/

# Editor / OS
.git
.gitignore
*.md
.vscode
.idea
.DS_Store
Thumbs.db

# Logs
*.log

# Build / distribution
dist/
build/

# Jupyter
.ipynb_checkpoints/
