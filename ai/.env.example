# =============================================================================
# AI Service Environment Variables
# Soundtrack My Night — FastAPI + OpenAI + Spotify
# =============================================================================
# Copy this file: cp ai/.env.example ai/.env
# Fill in ALL required values before running the application.
# =============================================================================

# ── OpenAI ────────────────────────────────────────────────────────────────────
# API key for OpenAI (used in openai_service.py to call gpt-4o-mini).
# Required: YES — playlist generation fails without this.
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-replace_with_your_openai_api_key

# ── Spotify Web API ───────────────────────────────────────────────────────────
# Client ID from your Spotify Developer App.
# Get from: https://developer.spotify.com/dashboard
# Required: YES
SPOTIFY_CLIENT_ID=replace_with_your_spotify_client_id

# Client Secret from your Spotify Developer App.
# Required: YES
SPOTIFY_CLIENT_SECRET=replace_with_your_spotify_client_secret

# OAuth 2.0 Refresh Token for the Spotify account that will OWN the playlists.
# This must be a User Refresh Token (not a client credentials token) because
# the service calls POST /v1/users/{user_id}/playlists (requires user scope).
#
# How to obtain:
#   1. Go to Spotify Developer Dashboard → your app → Edit Settings
#   2. Add http://localhost:8888/callback to Redirect URIs
#   3. Use the Authorization Code flow to authenticate with scopes:
#      playlist-modify-public playlist-modify-private
#   4. Exchange the code for tokens — copy the refresh_token value here.
#
# Required: YES — playlist creation on Spotify will fail without this.
SPOTIFY_REFRESH_TOKEN=replace_with_your_spotify_refresh_token
