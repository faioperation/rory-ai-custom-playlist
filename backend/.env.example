# =============================================================================
# Backend Environment Variables
# Soundtrack My Night — Node.js + Express 5
# =============================================================================
# Copy this file: cp backend/.env.example backend/.env
# Fill in ALL required values before running the application.
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on inside the container.
# Default: 3000 (used in src/config/constant.js as fallback)
PORT=3000

# Node environment. Controls cookie security (httpOnly secure flag).
# Values: development | production
NODE_ENV=production

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Full MongoDB connection string.
# Development (local mongo container): mongodb://mongo:27017/smn_db
# Production (Atlas):                  mongodb+srv://user:pass@cluster.mongodb.net/smn_db
# Required: YES — application exits on startup if missing (see dbConnect.js)
MONGO_URI=mongodb://mongo:27017/smn_db

# ── JWT Authentication ────────────────────────────────────────────────────────
# Secret key used to sign and verify all JWT tokens (users and admin).
# Required: YES — authentication breaks without this.
# Minimum recommended length: 64 characters of random characters.
JWT_SECRET=replace_with_a_64_char_random_string

# JWT token expiry. Examples: 7d | 30d | 24h
# Required: YES
JWT_EXPIRES_IN=30d

# ── URLs ──────────────────────────────────────────────────────────────────────
# The public URL of the frontend application.
# Used for:
#   - Playlist email links (quiz.service.js: FRONTEND_URL/playlist/:id)
#   - Stripe success/cancel redirect URLs (quiz.service.js)
# Required: YES — email playlist links will be broken without this.
# Development: http://localhost:5173
# Production:  https://soundtrackmynight.com
FRONTEND_URL=http://localhost:5173

# The public URL of the backend (self-referencing).
# Used as a default base URL fallback in constant.js.
# Development: http://localhost:3000
# Production:  https://api.soundtrackmynight.com (or same domain via nginx)
BACKEND_URL=http://localhost:3000

# CORS allowed origin (defined in constant.js but currently not used in CORS
# config — the CORS allowed list is hardcoded in app.js).
# Included here for future use / documentation.
ALLOWED_ORIGIN=http://localhost:5173

# ── AI Microservice ───────────────────────────────────────────────────────────
# URL of the FastAPI AI playlist generator service.
# Development (local):          http://localhost:8000
# Docker development:           http://ai:8000   (set in docker-compose.yml)
# Docker production:            http://ai:8000   (set in docker-compose.prod.yml)
# Required: YES — quiz submission fails without this.
AI_ENDPOINT=http://ai:8000

# ── Email (SMTP — Hostinger) ──────────────────────────────────────────────────
# Credentials for sending transactional emails (OTP, playlist links).
# SMTP host is currently hardcoded to smtp.hostinger.com:587 in email.js.
# Required: YES — password reset and playlist delivery emails will fail.
EMAIL_USER=info@soundtrackmynight.com
EMAIL_PASS=replace_with_your_email_password

# ── Stripe Payments ───────────────────────────────────────────────────────────
# Stripe secret key (starts with sk_live_ for production, sk_test_ for testing)
# Required: YES — paid playlist checkout and webhook verification break without this.
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key

# Stripe webhook signing secret (starts with whsec_).
# Obtained from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret.
# Required: YES — webhook signature verification will reject all events.
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret
